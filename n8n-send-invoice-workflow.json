            "type": "main",
            "index": 0
          },
          {
            "node": "Ada Email?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Ada No. WA?": {
      "main": [
        [
          {
            "node": "Kirim WA via WAHA",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Ada Email?": {
      "main": [
        [
          {
            "node": "Kirim Email",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    }
  },
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "pinData": {}
}
